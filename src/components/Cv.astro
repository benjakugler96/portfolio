---
// Front-end CV in two languages. Plain download links — no JS, no external
// fetch. Drop the two PDFs in /public/cv/ with these exact names. The `download`
// attribute forces the saved filename (e.g. "benjamin-kugler-es.pdf").
const cvs = [
  {
    kind: "PDF · Español",
    label: "CV en Español",
    file: "/cv/benjamin-kugler-es.pdf",
    download: "benjamin-kugler-es.pdf",
  },
  {
    kind: "PDF · English",
    label: "CV in English",
    file: "/cv/benjamin-kugler-en.pdf",
    download: "benjamin-kugler-en.pdf",
  },
];
---

<section class="section cv" id="cv">
  <div class="shell cv__inner reveal">
    <div class="cv__copy">
      <p class="section__index mono">05 / Résumé</p>
      <h2 class="section__title">Grab the CV.</h2>
      <p class="cv__note">Front-end résumé — pick your language.</p>
    </div>

    <div class="cv__buttons">
      {
        cvs.map((c) => (
          <a class="cv-btn" href={c.file} download={c.download} aria-label={`Download ${c.label}`}>
            <span class="cv-btn__kind mono">{c.kind}</span>
            <span class="cv-btn__label">{c.label}</span>
            <span class="cv-btn__icon" aria-hidden="true">
              ↓
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
